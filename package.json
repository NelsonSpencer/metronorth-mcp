{
  "name": "metronorth-mcp",
  "version": "2.0.0",
  "description": "Production-grade MCP server for Metro-North Railroad schedules and real-time data",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "metronorth-mcp": "./build/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/infrastructure/migrate.ts",
    "gtfs:update": "tsx src/infrastructure/update-gtfs.ts",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "metro-north",
    "gtfs",
    "transit",
    "mta",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.6.0",
    "csv-parser": "^3.0.0",
    "drizzle-orm": "^0.37.0",
    "express": "^4.21.2",
    "fuse.js": "^7.0.0",
    "gtfs-realtime-bindings": "^1.1.1",
    "ioredis": "^5.4.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
