{
  "name": "metronorth-mcp",
  "version": "2.1.2",
  "description": "MCP server for Metro-North schedules, stations, service alerts, and real-time departures",
  "type": "module",
  "packageManager": "npm@11.4.1",
  "main": "build/index.js",
  "bin": {
    "metronorth-mcp": "build/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NelsonSpencer/metronorth-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/NelsonSpencer/metronorth-mcp/issues"
  },
  "homepage": "https://github.com/NelsonSpencer/metronorth-mcp#readme",
  "files": [
    "build",
    "docs",
    ".env.example",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "GOVERNANCE.md",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "SUPPORT.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node scripts/clean-build.mjs && tsc",
    "start": "node build/index.js",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "smoke:mcp": "npm run build && node scripts/smoke-mcp.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/infrastructure/migrate.ts",
    "gtfs:update": "tsx src/infrastructure/update-gtfs.ts",
    "prepare": "npm run build && node scripts/prepare.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "typescript",
    "metro-north",
    "gtfs",
    "transit",
    "mta",
    "automation"
  ],
  "author": "Nelson Spencer",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.16.1",
    "better-sqlite3": "^12.10.0",
    "csv-parser": "^3.0.0",
    "fuse.js": "^7.0.0",
    "ioredis": "^5.4.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "protobufjs": "^8.6.5",
    "zod": "^3.23.8",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
