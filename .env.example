# Metro-North MCP Server Configuration

# Environment
NODE_ENV=development

# Logging level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Redis URL for caching (optional, falls back to in-memory cache)
REDIS_URL=

# Database path (default: ./db/metronorth.db)
DB_PATH=./db/metronorth.db

# GTFS update interval in hours (default: 24)
GTFS_UPDATE_INTERVAL_HOURS=24

# Real-time polling interval in milliseconds (default: 30000)
REALTIME_POLL_INTERVAL_MS=30000

# HTTP port for health/metrics endpoints (default: 6767)
HTTP_PORT=6767

# Cache TTL in seconds (default: 300)
CACHE_TTL_SECONDS=300
