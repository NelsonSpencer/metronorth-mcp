# Metro-North MCP Server Configuration

# Environment
NODE_ENV=development

# Logging level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Redis URL for caching (optional, falls back to in-memory cache)
REDIS_URL=

# Database path
# Optional. Defaults to ~/.cache/metronorth-mcp/metronorth.db when unset.
DB_PATH=

# GTFS update interval in hours (default: 24)
GTFS_UPDATE_INTERVAL_HOURS=24

# Cache TTL in seconds (default: 300)
CACHE_TTL_SECONDS=300

# Opt-in HTTP transport (stdio stays the default). CLI flags override these.
# Enable the Streamable HTTP transport (1, true, yes, or on)
MCP_HTTP=
# HTTP bind address (default: 127.0.0.1; never defaults to 0.0.0.0)
MCP_HTTP_HOST=127.0.0.1
# HTTP listen port (default: 8000)
MCP_HTTP_PORT=8000
# Require "Authorization: Bearer <token>" on /mcp (set one before any non-loopback exposure)
MCP_HTTP_TOKEN=
# Comma-separated Host allow-list for DNS-rebind protection (default: loopback names)
MCP_HTTP_ALLOWED_HOSTS=
# Comma-separated Origin allow-list for DNS-rebind protection (default: unset)
MCP_HTTP_ALLOWED_ORIGINS=
